# App Configuration
PROJECT_NAME="EdTech SaaS Platform"
ENV=development
DEBUG=true
API_V1_STR=/api/v1
SECRET_KEY=super-secret-key-change-in-production-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Database Configuration (PostgreSQL)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=edtech_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Caching Configuration (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=DEBUG
JSON_LOGS=false
